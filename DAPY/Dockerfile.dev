FROM python:3.11-slim

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Create app directory
WORKDIR /app

# Install Python dependencies (including dev dependencies)
COPY pyproject.toml ./
COPY README.md ./

RUN pip install --upgrade pip && \
    pip install -e ".[dev]"

# Note: Application code is mounted as volume for hot reload
# No COPY of dapy/ directory

# Create directories
RUN mkdir -p /app/data /app/snapshots /app/logs

# Set up git config
RUN git config --global user.name "DAPY Dev" && \
    git config --global user.email "dev@localhost"

# Expose port
EXPOSE 8000

# Default command for development
CMD ["dapy", "--help"]
