# Git mailmap for identity-collapse rewrites.
# Copy this file, edit per job. Format:
#   <preferred> <match-email>            -- match by commit email only
#   <preferred> Bad Name <match-email>    -- match by name + email
#
# To discover current identities in a repo:
#   git shortlog -sen --branches                        # authors
#   git log --branches --format='%cn <%ce>' | sort -u   # committers

