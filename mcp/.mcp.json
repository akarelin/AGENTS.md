{
  "mcpServers": {
    "Karelin Keys": {
      "type": "http",
      "url": "https://your-mcp-host/keys",
      "headers": {
        "Authorization": "Bearer ${MCP_KARELIN_TOKEN}"
      }
    },
    "M365": {
      "type": "http",
      "url": "https://your-mcp-host/m365",
      "headers": {
        "Authorization": "Bearer ${MCP_KARELIN_TOKEN}"
      }
    },
    "M365 Admin": {
      "type": "http",
      "url": "https://your-mcp-host/m365-admin",
      "headers": {
        "Authorization": "Bearer ${MCP_KARELIN_TOKEN}"
      }
    },
    "Obsidian": {
      "type": "http",
      "url": "https://your-mcp-host/obsidian",
      "headers": {
        "Authorization": "Bearer ${MCP_KARELIN_TOKEN}"
      }
    }
  }
}
