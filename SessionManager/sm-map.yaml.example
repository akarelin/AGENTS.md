# sm-map.yaml — User session & project map
# 
# Each user creates this file to declare where their LLM sessions
# and projects live. sm tools use it for discovery, navigation, and sync.
#
# Location: ~/.config/sm/map.yaml or ./sm-map.yaml

user:
  name: alex
  email: alex@karel.in

# ── Session sources ──────────────────────────────────────────────────────────
# Declare all locations where LLM session logs exist.
# Each source has a type, path, and optional host (for remote).

sources:
  # Local LLM tools (auto-discovered via rules, but can override/add)
  - name: Claude Code
    type: claude-code
    path: ~/.claude/projects
    host: local

  - name: Claude Code (Vertex)
    type: claude-code
    path: ~/.claude-vertex/projects
    host: local

  - name: OpenClaw
    type: openclaw
    path: ~/.openclaw/agents
    host: local

  - name: Claude Desktop
    type: claude-desktop
    path: ~/Library/Application Support/Claude/local-agent-mode-sessions
    host: local

  # Remote hosts
  - name: Claude Code (Server)
    type: claude-code
    path: ~/.claude/projects
    host: alex@34.162.201.120

  - name: Claude Code Vertex (Server)
    type: claude-code
    path: ~/.claude-vertex/projects
    host: alex@34.162.201.120

  # Exported archives
  - name: ChatGPT Export
    type: chatgpt-export
    path: ~/Downloads/chatgpt-2026-04.zip

  - name: Claude.ai Export
    type: claude-export
    path: ~/Downloads/claude-export-2026.zip

# ── Projects ─────────────────────────────────────────────────────────────────
# Map project names to directories, repos, and related session sources.

projects:
  - slug: neuronet
    name: Neuronet
    paths:
      - ~/RAN/AI/neuronet
    repos:
      - akarelin/neuronet
    tags: [ai, agents, slack]

  - slug: tool-catalog
    name: Xsolla Tool Catalog
    paths:
      - ~/xsolla-tool-catalog
    repos:
      - akarelin/xsolla-tool-catalog
    tags: [neo4j, saas, ontology]

  - slug: office-fortress
    name: Office Fortress
    paths:
      - ~/office-fortress
    repos:
      - akarelin/office-fortress
    tags: [security, gamification]

  - slug: greenjosh
    name: GreenJosh
    paths:
      - ~/GreenJosh
    tags: [smart-home, josh-ai]

  - slug: session-manager
    name: Session Manager
    paths:
      - ~/RAN/AI/SessionManager
    repos:
      - akarelin/SessionManager
    tags: [meta, llm-logs]

  - slug: preservator
    name: Preservator
    paths:
      - ~/CRAP/preservator
    tags: [backup, archival]

# ── Sync targets ─────────────────────────────────────────────────────────────
# Where to push session data.

sync:
  langfuse:
    host: https://langfuse.karelin.ai
    public_key: pk-lf-xsolla-main-2026
    secret_key: sk-lf-xsolla-main-2026-secret-changeme

  folder_store:
    path: /mnt/nas/sessions              # shared folder (optional)
    # path: ~/Dropbox/sessions           # or cloud sync

# ── Options ──────────────────────────────────────────────────────────────────

options:
  auto_discover: true                    # also run rule-based discovery
  auto_associate: true                   # auto-link sessions to projects by cwd match
  exclude_subagents: false               # include subagent sessions
